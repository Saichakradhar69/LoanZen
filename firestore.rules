/**
 * @fileoverview Firestore Security Rules for LoanZen application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. All data is nested under
 * /users/{userId}, and users can only access data associated with their own user ID.
 * Denormalization is used for efficient and secure authorization checks.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/loans/{loanId}: Stores loan details for a user.
 * - /users/{userId}/loans/{loanId}/payments/{paymentId}: Stores payment details for a loan.
 * - /users/{userId}/loans/{loanId}/rateHistory/{rateId}: Stores rate history for a loan.
 * - /users/{userId}/chats/{chatId}: Stores chat sessions for a user.
 * - /users/{userId}/chats/{chatId}/messages/{messageId}: Stores messages within a user's chat session.
 *
 * Key Security Decisions:
 * - Users can only access data under their own /users/{userId} path.
 * - Listing of user documents (e.g., GET on /users) is disallowed.
 * - Authorization-relevant data (e.g., subscriptionStatus) is denormalized into subcollections to avoid get() calls in rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Prevents listing all user documents. Only allows access to a specific user's document.
     * @path /users
     * @allow (get) Signed-in user can get their own user document.
     * @deny (get) Signed-in user cannot get another user's document.
     * @deny (list) No one can list all user documents.
     * @principle Prevents unauthorized access to user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);

      /**
       * @description Manages loan details for a specific user.
       * @path /users/{userId}/loans/{loanId}
       * @allow (create) Signed-in user can create a loan document under their user ID. The userId field in the document must match the userId in the path.
       * @allow (get, list) Signed-in user can read loan documents under their user ID.
       * @allow (update, delete) Signed-in user can update/delete their existing loan documents.
       * @deny (create) Signed-in user cannot create a loan document under another user's ID.
       * @principle Enforces user-ownership for loan documents.
       */
      match /users/{userId}/loans/{loanId} {
        allow get, list: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isSignedIn() && isExistingOwner(userId) && resource.data.userId == userId;
        allow delete: if isSignedIn() && isExistingOwner(userId);
      
        /**
         * @description Manages payments for a specific loan owned by a user.
         * @path /users/{userId}/loans/{loanId}/payments/{paymentId}
         * @allow (create) Signed-in user can create a payment document under their loan and user ID.
         * @allow (get, list) Signed-in user can read payment documents under their loan and user ID.
         * @allow (update, delete) Signed-in user can update/delete their existing payment documents.
         * @deny (create) Signed-in user cannot create a payment document under another user or loan ID.
         * @principle Enforces user-ownership for payment documents.
         */
        match /users/{userId}/loans/{loanId}/payments/{paymentId} {
          allow get, list: if isSignedIn() && isOwner(userId);
          allow create: if isSignedIn() && isOwner(userId);
          allow update: if isSignedIn() && isExistingOwner(userId);
          allow delete: if isSignedIn() && isExistingOwner(userId);
        }

        /**
         * @description Manages rate history for a specific loan owned by a user.
         * @path /users/{userId}/loans/{loanId}/rateHistory/{rateId}
         * @allow (create) Signed-in user can create a rate history document under their loan and user ID.
         * @allow (get, list) Signed-in user can read rate history documents under their loan and user ID.
         * @allow (update, delete) Signed-in user can update/delete their existing rate history documents.
         * @deny (create) Signed-in user cannot create a rate history document under another user or loan ID.
         * @principle Enforces user-ownership for rate history documents.
         */
        match /users/{userId}/loans/{loanId}/rateHistory/{rateId} {
          allow get, list: if isSignedIn() && isOwner(userId);
          allow create: if isSignedIn() && isOwner(userId);
          allow update: if isSignedIn() && isExistingOwner(userId);
          allow delete: if isSignedIn() && isExistingOwner(userId);
        }
      }

        /**
         * @description Manages chat sessions for a user.
         * @path /users/{userId}/chats/{chatId}
         * @allow (create) Signed-in user can create a chat document under their user ID.
         * @allow (get, list) Signed-in user can read chat documents under their user ID.
         * @allow (update, delete) Signed-in user can update/delete their existing chat documents.
         * @deny (create) Signed-in user cannot create a chat document under another user's ID.
         * @principle Enforces user-ownership for chat documents.
         */
        match /users/{userId}/chats/{chatId} {
          allow get, list: if isSignedIn() && isOwner(userId);
          allow create: if isSignedIn() && isOwner(userId);
          allow update: if isSignedIn() && isExistingOwner(userId);
          allow delete: if isSignedIn() && isExistingOwner(userId);

            /**
             * @description Manages chat messages within a user's chat session.
             * @path /users/{userId}/chats/{chatId}/messages/{messageId}
             * @allow (create) Signed-in user can create a chat message document under their chat and user ID.
             * @allow (get, list) Signed-in user can read chat message documents under their chat and user ID.
             * @allow (update, delete) Signed-in user can update/delete their existing chat message documents.
             * @deny (create) Signed-in user cannot create a chat message document under another user's or chat ID.
             * @principle Enforces user-ownership for chat message documents.
             */
            match /users/{userId}/chats/{chatId}/messages/{messageId} {
              allow get, list: if isSignedIn() && isOwner(userId);
              allow create: if isSignedIn() && isOwner(userId);
              allow update: if isSignedIn() && isExistingOwner(userId);
              allow delete: if isSignedIn() && isExistingOwner(userId);
            }
        }
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}