rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simple rules for development - allows authenticated users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow authenticated users to manage their loans
      match /loans/{loanId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow authenticated users to manage their payments
      match /loans/{loanId}/payments/{paymentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Allow authenticated users to manage their rate history
      match /loans/{loanId}/rateHistory/{rateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}