/**
 * @file Firestore Security Rules for LoanZen application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user has full control over their own data, and no access to other users' data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, ensuring clear ownership and easy path-based security.
 * /users/{userId} : Stores user profiles.
 * /users/{userId}/loans/{loanId} : Stores loan details associated with a specific user.
 * /users/{userId}/loans/{loanId}/payments/{paymentId} : Stores payment details for a specific loan owned by a user.
 * /users/{userId}/loans/{loanId}/rateHistory/{rateId} : Stores the rate history for a specific loan owned by a user.
 * /users/{userId}/chats/{chatId}: Stores chat sessions for a user.
 * /users/{userId}/chats/{chatId}/messages/{messageId}: Stores messages within a user's chat session.
 *
 * Key Security Decisions:
 * - Strict ownership: Only the authenticated user matching the `userId` path segment can read or write data within that path.
 * - No listing of all users: There is no rule allowing listing of the top-level `/users` collection. This prevents enumeration of user IDs.
 *
 * Denormalization for Authorization:
 * The `subscriptionStatus` from the user document MUST be copied into each `loan` document (and potentially into payments and rateHistory as well, if needed) to avoid costly `get()` calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a user to manage their own profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile if authenticated as 'user123'.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123' when authenticated as 'user456'.
     * @principle Enforces document ownership and ID consistency for user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == userId; // Enforce immutability
      allow delete: if isOwner(userId) && resource != null; // Ensure the document exists before deleting

    }

    /**
     * @description Allows a user to manage their own loans.
     * @path /users/{userId}/loans/{loanId}
     * @allow (create) User 'user123' can create a loan under their profile.
     * @deny (update) User 'user456' cannot update a loan under 'user123' profile.
     * @principle Enforces user-ownership for loan data.
     */
    match /users/{userId}/loans/{loanId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId && resource != null; //Enforce immutability and check for existance
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows a user to manage their own loan payments.
     * @path /users/{userId}/loans/{loanId}/payments/{paymentId}
     * @allow (create) User 'user123' can create a payment record for their loan.
     * @deny (delete) User 'user456' cannot delete payment records under 'user123' loan.
     * @principle Enforces user-ownership for loan payment data.
     */
    match /users/{userId}/loans/{loanId}/payments/{paymentId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows a user to manage the rate history of their loans.
     * @path /users/{userId}/loans/{loanId}/rateHistory/{rateId}
     * @allow (create) User 'user123' can create a rate history record for their loan.
     * @deny (update) User 'user456' cannot modify rate history records under 'user123' loan.
     * @principle Enforces user-ownership for loan rate history data.
     */
    match /users/{userId}/loans/{loanId}/rateHistory/{rateId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows a user to manage their own chats.
     * @path /users/{userId}/chats/{chatId}
     * @allow (create) User 'user123' can create a chat.
     * @deny (update) User 'user456' cannot update a chat under 'user123'.
     * @principle Enforces user-ownership for chat sessions.
     */
    match /users/{userId}/chats/{chatId} {
        function isOwner(userId) {
            return request.auth != null && request.auth.uid == userId;
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);

        allow create: if isOwner(userId);
        allow update: if isOwner(userId) && resource != null;
        allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows a user to manage their own chat messages.
     * @path /users/{userId}/chats/{chatId}/messages/{messageId}
     * @allow (create) User 'user123' can create a message in their chat.
     * @deny (delete) User 'user456' cannot delete messages in 'user123' chat.
     * @principle Enforces user-ownership for chat messages.
     */
    match /users/{userId}/chats/{chatId}/messages/{messageId} {
        function isOwner(userId) {
            return request.auth != null && request.auth.uid == userId;
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);

        allow create: if isOwner(userId);
        allow update: if isOwner(userId) && resource != null;
        allow delete: if isOwner(userId) && resource != null;
    }
  }
}