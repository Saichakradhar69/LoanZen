/**
 * @file Firestore Security Rules for LoanZen application.
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model, ensuring that each user can only access their own data.
 *   It uses path-based authorization, where the user ID in the path must match the authenticated user's UID.
 *   To avoid costly `get()` operations and maintain authorization independence, relevant user data (like 'subscriptionStatus') should be denormalized
 *   into subcollections (loans, payments, rateHistory).
 * @data_structure The data is organized hierarchically under `/users/{userId}`, with subcollections for loans, payments, and rate history.
 *   - /users/{userId}: Stores user profiles.
 *   - /users/{userId}/loans/{loanId}: Stores loan details for a user.
 *   - /users/{userId}/loans/{loanId}/payments/{paymentId}: Stores payment details for a loan.
 *   - /users/{userId}/loans/{loanId}/rateHistory/{rateId}: Stores rate history for a loan.
 * @key_security_decisions
 *   - Users can only access data under their own user ID.
 *   - List operations are scoped to the user's data and are allowed by default.
 *   - Data consistency between the path and internal document fields is enforced.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rule for user profiles.  Allows a user to read and write their own profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile if authenticated as 'user123'.
     * @allow (get) User with ID 'user123' can read their profile if authenticated as 'user123'.
     * @allow (update) User with ID 'user123' can update their profile if authenticated as 'user123'.
     * @allow (delete) User with ID 'user123' can delete their profile if authenticated as 'user123'.
     * @deny (create) User with ID 'user123' cannot create a profile if authenticated as 'user456'.
     * @deny (get) User with ID 'user123' cannot read the profile if authenticated as 'user456'.
     * @deny (update) User with ID 'user123' cannot update the profile if authenticated as 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete the profile if authenticated as 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for loan documents.  Allows a user to manage their own loans.
     * @path /users/{userId}/loans/{loanId}
     * @allow (create) User with ID 'user123' can create a loan if authenticated as 'user123'.
     * @allow (get) User with ID 'user123' can read a loan if authenticated as 'user123'.
     * @allow (update) User with ID 'user123' can update a loan if authenticated as 'user123'.
     * @allow (delete) User with ID 'user123' can delete a loan if authenticated as 'user123'.
     * @deny (create) User with ID 'user123' cannot create a loan if authenticated as 'user456'.
     * @deny (get) User with ID 'user123' cannot read the loan if authenticated as 'user456'.
     * @deny (update) User with ID 'user123' cannot update the loan if authenticated as 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete the loan if authenticated as 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/loans/{loanId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for payment documents.  Allows a user to manage their own payments.
     * @path /users/{userId}/loans/{loanId}/payments/{paymentId}
     * @allow (create) User with ID 'user123' can create a payment if authenticated as 'user123'.
     * @allow (get) User with ID 'user123' can read a payment if authenticated as 'user123'.
     * @allow (update) User with ID 'user123' can update a payment if authenticated as 'user123'.
     * @allow (delete) User with ID 'user123' can delete a payment if authenticated as 'user123'.
     * @deny (create) User with ID 'user123' cannot create a payment if authenticated as 'user456'.
     * @deny (get) User with ID 'user123' cannot read the payment if authenticated as 'user456'.
     * @deny (update) User with ID 'user123' cannot update the payment if authenticated as 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete the payment if authenticated as 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/loans/{loanId}/payments/{paymentId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.loanId == loanId;
      allow update: if isExistingOwner(userId) && request.resource.data.loanId == loanId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for rate history documents.  Allows a user to manage their own rate history.
     * @path /users/{userId}/loans/{loanId}/rateHistory/{rateId}
     * @allow (create) User with ID 'user123' can create a rate history if authenticated as 'user123'.
     * @allow (get) User with ID 'user123' can read a rate history if authenticated as 'user123'.
     * @allow (update) User with ID 'user123' can update a rate history if authenticated as 'user123'.
     * @allow (delete) User with ID 'user123' can delete a rate history if authenticated as 'user123'.
     * @deny (create) User with ID 'user123' cannot create a rate history if authenticated as 'user456'.
     * @deny (get) User with ID 'user123' cannot read the rate history if authenticated as 'user456'.
     * @deny (update) User with ID 'user123' cannot update the rate history if authenticated as 'user456'.
     * @deny (delete) User with ID 'user123' cannot delete the rate history if authenticated as 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/loans/{loanId}/rateHistory/{rateId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.loanId == loanId;
      allow update: if isExistingOwner(userId) && request.resource.data.loanId == loanId;
      allow delete: if isExistingOwner(userId);
    }
  }
}